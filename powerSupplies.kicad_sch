	)
	(text_box "R_{ENT}=((V/1.23)-1) x R_{ENB}\n	=((10.5/1.23)-1) x 21.5k\n	= 162.03k => 162k Ohm\n\nEN = ((21.5+162)/21.5)x1.23\n	= 10.49V\nDIS = ((21.5+162)/21.5)x1.1\n	= 9.38V"
		(exclude_from_sim no)
		(at 153.67 82.55 0)
		(size 27.94 19.05)
		(margins 0.9525 0.9525 0.9525 0.9525)
