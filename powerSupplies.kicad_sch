	)
	(text_box "DESIGN NOTE:\n\nC_{d}=5*C=18uF\nZ_{0} = sqrt(L/C)\n=sqrt(2.2/3.1)=0.84ohm\n"
		(exclude_from_sim no)
		(at 57.15 82.55 0)
