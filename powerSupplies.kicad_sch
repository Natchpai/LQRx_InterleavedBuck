	(text_box "Feeback Resistor\nR_{FBT} = ((V_{OUT}-V_{REF})/ V_{REF}) x R_{FBB}\n	= ((9 - 0.8)/ 0.8) x 22.5k\n	= ~220.3k Ohm\n\nV_{OUT} = V_{REF} x (1 + R_{FBT}/R_{FBB})\n	  = 0.8 x (1 + (221/22.5))\n	  = 9.023V"
		(exclude_from_sim no)
		(at 186.69 82.5762 0)
		(size 29.21 19.0238)
		(margins 0.9525 0.9525 0.9525 0.9525)
