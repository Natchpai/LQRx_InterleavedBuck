	)
	(text_box "DESIGN NOTE:\n\nThe EN rising threshold is 1.23V\nThe EN falling threshold is 1.1V\n\nWhen V_{EN} pin is below 0.95V(min)\nthe device is in shutdown mode."
		(exclude_from_sim no)
		(at 120.65 82.55 0)
		(size 31.75 19.05)
		(margins 0.9525 0.9525 0.9525 0.9525)
