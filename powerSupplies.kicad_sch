		(uuid "81a4d86a-ac0e-43cf-b84b-52158fdcecc4")
	)
	(text_box "Feedback Resistot\nR_{FBT} = ((V_{OUT}-V_{REF})/ V_{REF}) x R_{FBB}\n	= ((5 - 0.8)/ 0.8) x 21.5k\n	= 116k Ohm\n\nV_{OUT} = V_{REF} x (1 + R_{FBT}/R_{FBB})\n	  = 0.8 x (1 + (118/22.5))\n	  = 5.19V"
		(exclude_from_sim no)
