	(text_box "Output Capacitor\nC_{OUT} > 0.5 x (8 x I)/(f x DeltaVo)\n	  > 0.5x(8x0.6)/(1.1Meg x 0.2)\nC_{OUT} > 11uF , Transient Load (0.6A)\n\nDerated -44% @9V = 2.79uF\n3x3.79 = 8.37uF"
		(exclude_from_sim yes)
		(at 218.44 82.55 0)
		(size 33.02 19.05)
