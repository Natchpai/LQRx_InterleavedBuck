	(text_box "DESIGN NOTE:\n\n\nInput Capacitors 4.7uFx8 Derating -33% @24V = 25.2uF\n\nCd = 4*C = 100uF\n\nZ_{0} = sqrt(L/C) = sqrt(1/25.2)=0.199ohm\nRd = Z_{0}^{2} / ( Z_{0}/Q - DCR ) \n\nQ=0.9, DCR=15m => Rd = 0.192Ohm."
		(exclude_from_sim no)
		(at 263.5771 41.9387 0)
